rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read, write: if true;
    }
    match /settings/{settingsId} {
      allow read, write: if true;
    }
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
  }
}
